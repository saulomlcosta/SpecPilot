# Ambiente geral
ASPNETCORE_ENVIRONMENT=Development
APP_PORT=8080
WEB_PORT=3000
VITE_API_BASE_URL=http://localhost:8080
Cors__AllowedOrigins=http://localhost:3000;http://127.0.0.1:3000

# Banco de dados
POSTGRES_DB=specpilot
POSTGRES_USER=specpilot
POSTGRES_PASSWORD=specpilot
POSTGRES_PORT=5432
DATABASE_URL=Host=postgres;Port=5432;Database=specpilot;Username=specpilot;Password=specpilot

# API
JWT_ISSUER=SpecPilot
JWT_AUDIENCE=SpecPilot
JWT_SECRET_KEY=ChangeThisSecretKeyInFutureStages123!
JWT_EXPIRATION_MINUTES=60

# IA
Ai__Provider=Fake
Ai__OpenAi__ApiKey=
Ai__OpenAi__Model=gpt-4.1-mini
